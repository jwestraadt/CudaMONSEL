{
  "schema_version": 1,
  "run_tests": false,
  "simulations": [
    {
      "type": "composite_image",
      "name": "gamma + sigma (buried) inline-detector test @ 1 keV (GPU)",
      "enabled": true,
      "output_csv": "image_det_test_gpu.csv",
      "beam_energy_ev": 1000.0,
      "beam_size_nm": 0.5,
      "trajectories_per_pixel": 400,
      "secondary_electron_threshold_ev": 50.0,
      "histogram_bin_size_ev": 10.0,
      "backend": "gpu",

      "detectors": [
        { "name": "all",     "energy_min_ev": 0.0,  "energy_max_ev": 2000.0, "polar_min_deg": 0.0, "polar_max_deg": 90.0 },
        { "name": "se_all",  "energy_min_ev": 0.0,  "energy_max_ev": 50.0,   "polar_min_deg": 0.0, "polar_max_deg": 90.0 },
        { "name": "bse_all", "energy_min_ev": 50.0, "energy_max_ev": 2000.0, "polar_min_deg": 0.0, "polar_max_deg": 90.0 },
        { "name": "inlens",  "preset": "inlens_se" },
        { "name": "annular", "preset": "annular_bse", "working_distance_mm": 5.0, "inner_radius_mm": 3.0, "outer_radius_mm": 8.0 },
        { "name": "etd",     "preset": "etd_se" }
      ],

      "scattering": { "elastic": "nist_mott", "inelastic": "fitted", "csd": "joy_luo_nieminen", "barrier": "exp_qm" },
      "scan": { "center_x_nm": 0.0, "center_y_nm": 0.0, "half_width_nm": 90.0, "nx_pixels": 32, "ny_pixels": 32 },

      "matrix_phase": {
        "name": "gamma",
        "density_kg_m3": 8700.0, "work_function_ev": 5.15, "fermi_energy_ev": 8.8, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0, "break_energy_ev": 45.0,
        "composition": { "Ni": 63.0, "Cr": 8.0, "Co": 10.0, "W": 6.0, "Re": 4.0, "Al": 6.0, "Ta": 3.0 }
      },
      "precipitate_phase": {
        "name": "sigma_ReWCoNiCr",
        "density_kg_m3": 14000.0, "work_function_ev": 4.8, "fermi_energy_ev": 8.5, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0, "break_energy_ev": 45.0,
        "composition": { "Re": 32.0, "W": 30.0, "Co": 16.0, "Ni": 12.0, "Cr": 12.0 }
      },
      "precipitate": { "shape": "sphere", "radius_nm": 30.0, "center_depth_nm": 30.0, "center_x_nm": 0.0, "center_y_nm": 0.0 }
    }
  ]
}
