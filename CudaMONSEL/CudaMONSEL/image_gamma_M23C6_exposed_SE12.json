        "secondary_generation_energy_ev": 32.0, "break_energy_ev": 45.0,
        "composition": { "Cr": 23.0, "C": 6.0 }
      },
      "precipitate": { "shape": "sphere", "radius_nm": 30.0, "center_depth_nm": 0.0, "center_x_nm": 0.0, "center_y_nm": 0.0 }
    },
