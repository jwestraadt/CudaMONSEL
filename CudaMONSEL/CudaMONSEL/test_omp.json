{
  "schema_version": 1,
  "run_tests": false,
  "simulations": [
    {
      "type": "composite_image",
      "name": "OMP test 4x4",
      "enabled": true,
      "output_csv": "test_omp.csv",
      "output_pgm_se": "test_omp_SE.pgm",
      "output_pgm_bse": "test_omp_BSE.pgm",

      "beam_energy_ev": 5000.0,
      "beam_size_nm": 0.5,
      "trajectories_per_pixel": 10,
      "secondary_electron_threshold_ev": 50.0,
      "histogram_bin_size_ev": 10.0,

      "scattering": {
        "elastic": "nist_mott",
        "inelastic": "fitted",
        "csd": "joy_luo_nieminen",
        "barrier": "exp_qm"
      },

      "scan": {
        "center_x_nm": 0.0,
        "center_y_nm": 0.0,
        "half_width_nm": 30.0,
        "nx_pixels": 4,
        "ny_pixels": 4
      },

      "matrix_phase": {
        "name": "gamma",
        "density_kg_m3": 8700.0,
        "work_function_ev": 5.15,
        "fermi_energy_ev": 8.8,
        "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0,
        "break_energy_ev": 45.0,
        "composition": {
          "Ni": 63.0, "Cr": 8.0, "Co": 10.0, "W": 6.0, "Re": 4.0, "Al": 6.0, "Ta": 3.0
        }
      },

      "precipitate_phase": {
        "name": "gamma_prime",
        "density_kg_m3": 8200.0,
        "work_function_ev": 4.9,
        "fermi_energy_ev": 7.5,
        "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0,
        "break_energy_ev": 45.0,
        "composition": {
          "Ni": 75.0, "Al": 12.0, "Ti": 5.0, "Ta": 5.0, "Cr": 3.0
        }
      },

      "precipitate": {
        "shape": "sphere",
        "radius_nm": 30.0,
        "center_depth_nm": 0.0,
        "center_x_nm": 0.0,
        "center_y_nm": 0.0
      }
    }
  ]
}
