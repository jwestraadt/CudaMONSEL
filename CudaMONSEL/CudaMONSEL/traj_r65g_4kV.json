{
  "schema_version": 1,
  "run_tests": false,
  "simulations": [
    {
      "type": "composite_image",
      "name": "Rene65 gamma matrix, single-probe trajectory capture @ 4 keV",
      "enabled": true,
      "output_csv": "traj_r65g_4kV.csv",

      "beam_energy_ev": 4000.0,
      "beam_size_nm": 0.5,
      "trajectories_per_pixel": 15000,
      "secondary_electron_threshold_ev": 50.0,
      "histogram_bin_size_ev": 10.0,
      "backend": "cpu",

      "trajectory_capture": {
        "enabled": true,
        "max_full_paths": 200,
        "max_escape_events": 60000,
        "step_stride": 3,
        "record_secondaries": true,
        "include_absorbed": true,
        "output": "traj_r65g_4kV"
      },

      "scattering": { "elastic": "nist_mott", "inelastic": "fitted", "csd": "joy_luo_nieminen", "barrier": "exp_qm" },
      "scan": { "center_x_nm": 0.0, "center_y_nm": 0.0, "half_width_nm": 10.0, "nx_pixels": 1, "ny_pixels": 1 },

      "matrix_phase": {
        "name": "gamma_R65",
        "density_kg_m3": 8300.0, "work_function_ev": 5.0, "fermi_energy_ev": 8.8, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0, "break_energy_ev": 45.0,
        "composition": { "Ni": 42.5, "Cr": 29.2, "Co": 20.9, "Mo": 4.1, "W": 2.2, "Ti": 1.0, "Al": 0.1, "Nb": 0.1 }
      },
      "precipitate_phase": {
        "name": "gammaP_R65",
        "density_kg_m3": 7950.0, "work_function_ev": 4.8, "fermi_energy_ev": 7.5, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 28.0, "break_energy_ev": 45.0,
        "composition": { "Ni": 72.5, "Al": 10.3, "Ti": 10.4, "Cr": 3.1, "Co": 2.3, "Nb": 1.0, "Mo": 0.2, "W": 0.2 }
      },
      "precipitate": { "shape": "sphere", "radius_nm": 30.0, "center_depth_nm": 0.0, "center_x_nm": 1000.0, "center_y_nm": 0.0 }
    }
  ]
}
