{
  "schema_version": 1,
  "run_tests": false,
  "simulations": [
    {
      "type": "composite_image",
      "name": "Rene65 gamma'/gamma half-sphere @ 200 eV, 0.1 nm carbon (SE1/SE2/BSE)",
      "enabled": true,
      "output_csv": "image_r65_se12bse_200V.csv",
      "output_pgm_se1": "image_r65_se12bse_200V_SE1.pgm",
      "output_pgm_se2": "image_r65_se12bse_200V_SE2.pgm",
      "output_pgm_bse": "image_r65_se12bse_200V_BSE.pgm",

      "beam_energy_ev": 200.0,
      "beam_size_nm": 0.5,
      "trajectories_per_pixel": 5000,
      "secondary_electron_threshold_ev": 50.0,
      "histogram_bin_size_ev": 10.0,
      "backend": "gpu",

      "scattering": { "elastic": "nist_mott", "inelastic": "fitted", "csd": "joy_luo_nieminen", "barrier": "exp_qm" },
      "scan": { "center_x_nm": 0.0, "center_y_nm": 0.0, "half_width_nm": 90.0, "nx_pixels": 64, "ny_pixels": 64 },

      "surface_layer": {
        "thickness_nm": 0.1, "name": "carbon",
        "density_kg_m3": 2000.0, "work_function_ev": 5.0, "fermi_energy_ev": 5.0, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 35.0, "break_energy_ev": 30.0, "composition": { "C": 1.0 }
      },

      "matrix_phase": {
        "name": "gamma_R65",
        "density_kg_m3": 8300.0, "work_function_ev": 5.0, "fermi_energy_ev": 8.8, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 30.0, "break_energy_ev": 45.0,
        "composition": { "Ni": 42.5, "Cr": 29.2, "Co": 20.9, "Mo": 4.1, "W": 2.2, "Ti": 1.0, "Al": 0.1, "Nb": 0.1 }
      },
      "precipitate_phase": {
        "name": "gammaP_R65",
        "density_kg_m3": 7950.0, "work_function_ev": 4.8, "fermi_energy_ev": 7.5, "bandgap_ev": 0.0,
        "secondary_generation_energy_ev": 28.0, "break_energy_ev": 45.0,
        "composition": { "Ni": 72.5, "Al": 10.3, "Ti": 10.4, "Cr": 3.1, "Co": 2.3, "Nb": 1.0, "Mo": 0.2, "W": 0.2 }
      },
      "precipitate": { "shape": "sphere", "radius_nm": 30.0, "center_depth_nm": 0.0, "center_x_nm": 0.0, "center_y_nm": 0.0 }
    }
  ]
}
